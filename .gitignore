# ═══════════════════════════════════════════════════
#  .gitignore — Vite + React + Netlify Portfolio
# ═══════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ─────────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Environment Variables (NEVER commit secrets) ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Vite ──────────────────────────────────────────
*.local
.vite/

# ── Editor / IDE ──────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ── OS Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test & Coverage ───────────────────────────────
coverage/
.coverage/
*.lcov

# ── Misc ──────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
*.tgz
*.tar.gz
.netlify/

personal